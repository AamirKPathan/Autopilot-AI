{
  "name": "suna-control-room",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "api": "node server.mjs",
    "start": "node server.mjs",
    "dev": "concurrently \"npm:api\" \"vite\"",
    "desktop": "concurrently \"npm:api\" \"vite\" \"wait-on http://localhost:5173 http://127.0.0.1:8787/api/health && electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.suna.desktop",
    "productName": "Suna",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server.mjs",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "mongodb": "^7.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^22.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "vite": "^5.4.8",
    "wait-on": "^9.0.10"
  }
}
