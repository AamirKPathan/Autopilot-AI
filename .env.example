AI_PORT=8787
PORT=8787
APP_BASE_URL=http://localhost:8787
NODE_ENV=development

# Production auth/session
AUTH_REQUIRED=false
SESSION_DAYS=30
ADMIN_EMAILS=

# MongoDB Atlas or self-hosted MongoDB
MONGODB_URI=
MONGODB_DB=suna

# Open-source source repos
SUNA_REPO_URL=https://github.com/kortix-ai/suna
HERMES_REPO_URL=https://github.com/NousResearch/hermes-agent

# Local clone paths inside this workspace
SUNA_LOCAL_PATH=services/suna
HERMES_LOCAL_PATH=services/hermes

# Recommended localhost brain: Groq.
# Create a free Groq API key, paste it below, then restart the app.
GROQ_API_KEY=

SUNA_BASE_URL=https://api.groq.com/openai/v1
SUNA_API_KEY=
SUNA_MODEL=llama-3.3-70b-versatile
HERMES_BASE_URL=https://api.groq.com/openai/v1
HERMES_API_KEY=
HERMES_MODEL=llama-3.3-70b-versatile

AI_MAX_TOKENS=700

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8787/api/auth/microsoft/callback

# Stripe subscriptions
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLUS_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
